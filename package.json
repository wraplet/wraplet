  ],
  "scripts": {
    "setup": "pnpm install",
    "build": "webpack --mode production --config ./webpack.config.ts",
    "dev:build": "webpack --mode development --config ./webpack.config.ts",
    "dev:watch": "webpack --mode development --watch --config ./webpack.config.ts",
    "lint": "tsc --noemit && npx eslint './src/**/*.ts' './tests/**/*.ts'",
